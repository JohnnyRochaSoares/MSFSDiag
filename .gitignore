# Cache do Python (ficheiros compilados)
__pycache__/
*.py[cod]
*$py.class

# Ambientes Virtuais (Virtual Environments)
venv/
.venv/
env/
ENV/
build/
dist/

# Definições Locais do Utilizador
# Como o teu app.py usa load_settings() e save_settings(), ignora o ficheiro que guarda isso
# (ajusta o nome abaixo se o teu ficheiro de definições tiver outro nome, ex: config.json)
settings.json

# Logs do sistema ou da aplicação
*.log

# Editores de Código / IDEs
.vscode/
.idea/
*.swp
*.swo

# Ficheiros do Sistema Operativo
Thumbs.db
Desktop.ini
.DS_Store 
